# =========================
# Runtime mode
# =========================
# Local documents mode (default): false
# S3 download mode: true
USE_S3=false

# =========================
# Ollama / GPT-OSS
# =========================
# OpenAI-compatible Ollama endpoint
GPT_OSS_URL_API=http://localhost:11434/v1
GPT_OSS_MODEL=gpt-oss-120b
GPT_OSS_API_KEY=ollama

# =========================
# Optional S3 settings
# Used only when USE_S3=true
# =========================
S3_UPLOAD_BUCKET_NAME=aip-rag-ai
S3_ENDPOINT_URL=http://s3.dataplatform.samsungds.net:9020
S3_UPLOAD_BUCKET_ACCESS_KEY=
S3_UPLOAD_BUCKET_SECRET_KEY=
